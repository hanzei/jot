{
  "expo": {
    "name": "Jot",
    "slug": "jot",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "jot",
    "newArchEnabled": true,
    "platforms": [
      "ios",
      "android"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.jot.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.jot.app",
      "softwareKeyboardLayoutMode": "resize",
      "versionCode": 1
    },
    "plugins": [
      "expo-localization"
    ]
  }
}
