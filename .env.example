# Environment variables for Jot
# Copy this file to .env and update the values

# Database file path (for SQLite)
DB_PATH=./jot.db

# Server port (optional, defaults to 8080)
PORT=8080

# Path to the compiled frontend static files (optional, defaults to ../webapp/build relative to the working directory)
# STATIC_DIR=/app/webapp/build

# Allowed CORS origin for the frontend (must be exact origin, not a wildcard)
# Required when frontend and backend are on different origins
# CORS_ALLOWED_ORIGIN=https://app.example.com

# Set to "false" to disable the Secure flag on session cookies (for local HTTP development)
# Defaults to "true" — always keep true in production (requires HTTPS)
COOKIE_SECURE=true

# Set to "false" to disable new user registration (admin can still create users via jotctl)
# Defaults to "true"
# REGISTRATION_ENABLED=false

# Minimum password length (1–72, defaults to 10)
# PASSWORD_MIN_LENGTH=10

# --- Metrics (Prometheus) ---

# Set to "true" to expose a Prometheus metrics endpoint
# METRICS_ENABLED=false

# Host and port for the Prometheus metrics endpoint (defaults to 127.0.0.1:8081)
# METRICS_HOST=127.0.0.1
# METRICS_PORT=8081

# --- OpenTelemetry ---

# Set to "true" to enable OpenTelemetry tracing and logging export
# OTEL_ENABLED=false

# OTLP gRPC collector endpoint (required when OTEL_ENABLED=true)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Set to "true" to connect to the OTLP endpoint without TLS (for local collectors)
# OTEL_EXPORTER_OTLP_INSECURE=false

# Service name reported in traces and logs (defaults to "jot")
# OTEL_SERVICE_NAME=jot
